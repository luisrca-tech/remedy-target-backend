# remedy-target-backend — environment contract
# Copy to .env for local dev. NEVER commit real values (see .gitignore).

# --- Database ---
# Local dev: the docker-compose Postgres. Prod: the Neon connection string.
DATABASE_URL=postgres://remedy:remedy@localhost:5432/remedy_target

# --- Sentry (backend project) ---
# DSN for the backend Sentry project. Leave empty to disable capture locally.
SENTRY_DSN=
# environment tag; Railway injects this in prod.
SENTRY_ENVIRONMENT=development

# --- Release resolution ---
# In prod, Railway injects RAILWAY_GIT_COMMIT_SHA and it becomes the Sentry `release`.
# Locally you may set it to a checkout SHA for the CLI job; the service reads it if present.
RAILWAY_GIT_COMMIT_SHA=

# --- Bug selection ---
# Empty during `checks` (all bugs dormant). Known ids: BH1, BH2, BC1.
#   ENABLED_BUGS=BH1        -> only BH1 (the correct form for a live Remedy window)
#   ENABLED_BUGS=ALL        -> every known bug (LOCAL EXPLORATION ONLY)
#   ENABLED_BUGS=ALL,BH2    -> all except BH2 (under ALL, a bare id EXCLUDES it)
#   ENABLED_BUGS=ALL,-BH2   -> same; a leading - or ! is always an explicit exclude
# So: without ALL, ids are includes; with ALL, bare ids are excludes.
# WINDOW DISCIPLINE (D-6): a live Remedy window must enable EXACTLY ONE bug.
# ALL / multi-bug selection is a local-dev convenience and must never run a window.
ENABLED_BUGS=

# --- Server ---
PORT=3000

# --- Trigger scripts (scripts/trigger*.ts) — not read by the service ---
# Only needed when running the incident-trigger scripts locally. See scripts/README.md.
# Deployed backend base URL, required by triggerBH1.ts / triggerBH2.ts.
TARGET_URL=
# Sentry API creds for the tag-verification step (all three required to verify).
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
