# remedy-target-backend — environment contract
# Copy to .env for local dev. NEVER commit real values (see .gitignore).

# --- Database ---
# Local dev: the docker-compose Postgres. Prod: the Neon connection string.
DATABASE_URL=postgres://remedy:remedy@localhost:5432/remedy_target

# --- Sentry (backend project) ---
# DSN for the backend Sentry project. Leave empty to disable capture locally.
SENTRY_DSN=
# environment tag; Railway injects this in prod.
SENTRY_ENVIRONMENT=development

# --- Release resolution ---
# In prod, Railway injects RAILWAY_GIT_COMMIT_SHA and it becomes the Sentry `release`.
# Locally you may set it to a checkout SHA for the CLI job; the service reads it if present.
RAILWAY_GIT_COMMIT_SHA=

# --- Bug selection (window discipline) ---
# Exactly ONE bug id per window. Empty during `checks`. Known ids: BH1, BH2, BC1.
ENABLED_BUGS=

# --- Server ---
PORT=3000
