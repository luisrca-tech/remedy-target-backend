# Sundry API — environment contract.
# Copy to `.env` and fill in. `.env` is gitignored; never commit real values.

# --- Database ---
# Postgres connection string. Local docker-compose default shown.
DATABASE_URL=postgres://sundry:sundry@localhost:5432/sundry

# --- Server ---
# The storefront dev server owns 3000, so the API defaults to 8000.
PORT=8000

# Browser origins allowed to call this API cross-origin, comma-separated.
# The storefront calls these endpoints directly, so its origin must be listed.
CORS_ORIGINS=http://localhost:3000

# --- Error reporting ---
# Leave empty to disable Sentry entirely (tests and local runs stay offline).
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# Injected by Railway in deployed environments; used as the Sentry release.
RAILWAY_GIT_COMMIT_SHA=

# --- Rollout flags ---
# Comma-separated feature flags; see src/config/rollout.ts for the grammar.
# Empty means nothing is rolled out. `all` is local-development only.
ROLLOUT_FLAGS=
