{
  "version": 1,
  "app": {
    "directory": ".",
    "packageManager": "bun"
  },
  "setup": {
    "name": "install",
    "command": "bun install --frozen-lockfile",
    "timeoutSeconds": 300
  },
  "checks": [
    {
      "name": "test",
      "command": "bun run test",
      "timeoutSeconds": 600
    },
    {
      "name": "typecheck",
      "command": "bun run typecheck",
      "timeoutSeconds": 300
    },
    {
      "name": "lint",
      "command": "bun run lint",
      "timeoutSeconds": 300
    }
  ],
  "preview": {
    "provider": "github-deployment",
    "environmentPattern": "preview-*",
    "timeoutSeconds": 900
  },
  "fixtures": {
    "seed": {
      "name": "seed-catalog",
      "command": "bun run db:seed",
      "timeoutSeconds": 120
    },
    "reset": {
      "name": "reset-catalog",
      "command": "bun run db:reset",
      "timeoutSeconds": 120
    },
    "testTenant": "sundry"
  },
  "harnesses": {
    "browser": false,
    "http": true,
    "httpScenarios": [
      {
        "name": "catalog-first-page",
        "method": "GET",
        "path": "/products?page=1&perPage=12",
        "headers": {},
        "reproduceOnStatus": [
          500
        ]
      },
      {
        "name": "catalog-last-page",
        "method": "GET",
        "path": "/products?page=4&perPage=12",
        "headers": {},
        "reproduceOnStatus": [
          500
        ]
      },
      {
        "name": "catalog-search",
        "method": "GET",
        "path": "/products?q=kettle",
        "headers": {},
        "reproduceOnStatus": [
          500
        ]
      },
      {
        "name": "product-detail",
        "method": "GET",
        "path": "/products/prd_9c21",
        "headers": {},
        "reproduceOnStatus": [
          500
        ]
      },
      {
        "name": "cart-detail",
        "method": "GET",
        "path": "/carts/cart_live",
        "headers": {},
        "reproduceOnStatus": [
          500
        ]
      },
      {
        "name": "order-history",
        "method": "GET",
        "path": "/orders?userId=usr_4b8e",
        "headers": {},
        "reproduceOnStatus": [
          500
        ]
      },
      {
        "name": "checkout-submit",
        "method": "POST",
        "path": "/checkout",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": "{\"cartId\":\"cart_live\",\"shipping\":{\"street\":\"12 Rua das Flores\",\"city\":\"Porto\",\"postalCode\":\"4000 007\",\"country\":\"pt\"}}",
        "reproduceOnStatus": [
          500
        ]
      },
      {
        "name": "checkout-submit-partial",
        "method": "POST",
        "path": "/checkout",
        "headers": {
          "Content-Type": "application/json"
        },
        "body": "{\"cartId\":\"cart_live\"}",
        "reproduceOnStatus": [
          500
        ]
      }
    ],
    "commands": [
      {
        "name": "daily-digest",
        "command": "bun run job:digest",
        "timeoutSeconds": 120
      }
    ]
  },
  "security": {
    "secretRefs": [
      "DATABASE_URL",
      "SENTRY_DSN"
    ],
    "allowedEgress": [
      "api.github.com",
      "sentry.io",
      "*.neon.tech",
      "*.railway.app"
    ],
    "allowedSandboxEndpoints": []
  },
  "sandbox": {
    "cpuLimit": 2,
    "memoryLimitMb": 4096,
    "diskQuotaMb": 10240
  },
  "observation": {
    "windowDays": 7,
    "releaseDetectionTimeoutDays": 7
  },
  "patch": {
    "maxFiles": 8,
    "maxLines": 350,
    "forbiddenPaths": [
      "drizzle/",
      "infra/"
    ],
    "highRisk": {
      "dependencies": false,
      "migrations": false,
      "authentication": false,
      "infrastructure": false
    }
  }
}
