{
  "name": "sundry-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Sundry API \u2014 catalog, carts, checkout and order history for the Sundry storefront. Hono + Drizzle on Bun.",
  "scripts": {
    "dev": "bun run --hot src/index.ts",
    "start": "bun run src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "bun run src/db/seed.ts",
    "db:reset": "bun run src/db/reset.ts",
    "job:digest": "bun run src/jobs/runDigest.ts"
  },
  "engines": {
    "bun": ">=1.3.0"
  },
  "dependencies": {
    "@sentry/bun": "^10.66.0",
    "@sentry/node": "^10.66.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.30",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "^1.3.14",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.7.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.64.0"
  }
}
